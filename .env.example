# Copy this file to .env and fill in the values before running docker compose.
# The .env file must sit in the same folder as docker-compose.yml.

# ── Backend ──────────────────────────────────────────────────────────────────

# JWT secret (generate a strong random string, e.g. openssl rand -hex 32)
JWT_SECRET=change_me_to_a_strong_secret

# CORS origin — origin that the browser will send requests FROM
CORS_ORIGIN=http://localhost:3000

# Cloudinary (optional — for product image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Frontend ─────────────────────────────────────────────────────────────────

# Public URL of the backend (used at *build time* by React)
REACT_APP_BACKEND_URL=http://localhost:5000
